# Copy to .env and replace every CHANGE_ME value before starting OrbitOps.
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_GENERATE_AT_LEAST_32_RANDOM_CHARACTERS

# Docker Compose PostgreSQL
POSTGRES_DB=orbitops
POSTGRES_USER=orbitops
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_URL=postgresql+asyncpg://orbitops:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/orbitops

# Cache / workflow state
REDIS_URL=redis://redis:6379/0

# Browser and JWT session policy
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# Development/test bootstrap only; production users must be provisioned separately.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_BOOTSTRAP_ADMIN_PASSWORD

# LLM routing. Real providers remain disabled until both a key and live mode are set.
LLM_DEFAULT_PROVIDER=mock
LIVE_LLM_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=45

# Configure rates from your provider contract; zero disables cost estimation.
OPENAI_INPUT_COST_PER_MILLION=0
OPENAI_OUTPUT_COST_PER_MILLION=0
ANTHROPIC_INPUT_COST_PER_MILLION=0
ANTHROPIC_OUTPUT_COST_PER_MILLION=0
GOOGLE_INPUT_COST_PER_MILLION=0
GOOGLE_OUTPUT_COST_PER_MILLION=0

# Optional tracing. Review data-retention policy before enabling.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=orbitops

# Delivery is deny-by-default even when provider credentials exist.
DELIVERY_ENABLED=false
EMAIL_WEBHOOK_SECRET=CHANGE_ME_EMAIL_WEBHOOK_HMAC_SECRET
WHATSAPP_WEBHOOK_SECRET=CHANGE_ME_WHATSAPP_WEBHOOK_HMAC_SECRET
WEBHOOK_TOLERANCE_SECONDS=300
MESSAGE_MAX_ATTEMPTS=3

# Provider adapters
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
SMTP_URL=
SENDGRID_API_KEY=
AWS_REGION=

# Frontend/API routing
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
API_INTERNAL_URL=http://api:8000/api/v1
